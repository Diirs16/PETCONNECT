# ================================================================
# PETCONNECT - Plantilla de variables de entorno
# Copia este archivo como ".env" y completa tus propios valores.
# El archivo ".env" real NUNCA se sube a Git/GitHub (ver .gitignore).
# ================================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3310
DB_NAME=petconnect
DB_USER=root
DB_PASSWORD=

# Mailtrap (opcional). Si se deja vacio o el envio falla, el codigo de
# verificacion de registro se imprime en la consola del servidor,
# asi que la app funciona igual sin necesidad de un correo real.
MAILTRAP_API_TOKEN=
MAILTRAP_SENDER=noreply@tudominio.com
EMAIL_MODE=sdk

# Claves de seguridad: NO escribirlas a mano, se generan automaticamente
# ejecutando una sola vez:  python generate_keys.py
JWT_SECRET=
FERNET_KEY=
